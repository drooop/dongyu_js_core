# Cloud K8s deployment configuration (rke2 @ dongyudigital.com)
# Copy to cloud.env and fill in values:
#   cp deploy/env/cloud.env.example deploy/env/cloud.env

# Kubernetes
K8S_CONTEXT=default
NAMESPACE=dongyu
KUBECONFIG=/etc/rancher/rke2/rke2.yaml

# SSH (for remote deploy)
SSH_HOST=dongyudigital.com
SSH_USER=drop
REMOTE_REPO=/home/wwpic/dongyuapp
REMOTE_REPO_OWNER=wwpic
CLOUD_PERSISTED_ASSET_ROOT=/home/wwpic/dongyu/volume/persist/assets

# Synapse / Matrix
# Cloud deployments use the shared remote Matrix server by default.
# If this is unset, deploy scripts fall back to the in-cluster Synapse service.
MATRIX_HOMESERVER_URL=https://matrix.dongyudigital.com
SYNAPSE_SERVER_NAME=synapse.dongyudigital.com
SYNAPSE_SECRET=dongyu-synapse-secret-2026
SERVER_USER=drop
SERVER_PASSWORD=ChangeMeCloud2026
MBR_USER=mbr
MBR_PASSWORD=ChangeMeCloud2026

# MQTT
MQTT_HOST=emqx-emqx-enterprise.emqx.svc.cluster.local
MQTT_PORT=1883

# Containerd (rke2)
CTR=/usr/local/bin/ctr
CONTAINERD_SOCK=/run/k3s/containerd/containerd.sock

# UI Server
SEED_POSITIVE_MODELS_ON_BOOT=0
DY_AUTH=0
DY_OIDC_ISSUER=https://sso.dongyudigital.com
DY_OIDC_CLIENT_ID=
DY_OIDC_CLIENT_SECRET=
DY_OIDC_REDIRECT_URI=https://app.dongyudigital.com/auth/sso/callback
DY_OIDC_SCOPE="openid profile email urn:zitadel:iam:org:project:id:zitadel:aud urn:zitadel:iam:org:projects:roles"
# Required when DY_AUTH=1 on non-loopback domains. Use long random values.
DY_OIDC_STATE_SECRET=
DY_SESSION_SECRET=
DY_AUTH_SECRET=
