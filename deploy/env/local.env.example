# Local K8s deployment configuration
# Copy to local.env and fill in values:
#   cp deploy/env/local.env.example deploy/env/local.env

# Kubernetes
# Local context (recommended: orbstack; Docker Desktop users can set docker-desktop)
K8S_CONTEXT=orbstack
NAMESPACE=dongyu

# Matrix transport
# Local tests default to the remote Matrix server. Use explicit overrides only
# when you intentionally test a local Synapse instance.
MATRIX_HOMESERVER_URL=https://matrix.dongyudigital.com
SYNAPSE_SERVER_NAME=synapse.dongyudigital.com
SYNAPSE_SECRET=dongyu-synapse-secret-2026
SERVER_USER=drop
SERVER_PASSWORD=${REMOTE_MATRIX_DROP_PASSWORD:?set REMOTE_MATRIX_DROP_PASSWORD}
MBR_USER=mbr
MBR_PASSWORD=${REMOTE_MATRIX_MBR_PASSWORD:?set REMOTE_MATRIX_MBR_PASSWORD}

# MQTT
MQTT_HOST=mosquitto.dongyu.svc.cluster.local
MQTT_PORT=1883

# UI Server
SEED_POSITIVE_MODELS_ON_BOOT=0
DY_AUTH=1
DY_OIDC_ISSUER=https://sso.dongyudigital.com
DY_OIDC_CLIENT_ID=375920990745592038
DY_OIDC_CLIENT_SECRET=
DY_OIDC_REDIRECT_URI=http://localhost:30900/auth/sso/callback
DY_OIDC_SCOPE="openid profile email urn:zitadel:iam:org:project:id:zitadel:aud urn:zitadel:iam:org:projects:roles"
DY_OIDC_STATE_SECRET=
DY_SESSION_SECRET=
DY_AUTH_SECRET=
