      "r": 0,
      "c": 0,
      "k": "on_model100_submit_in",
      "t": "func.js",
      "v": {
        "code": "const payload = Array.isArray(label && label.v) ? label.v : [];\nif (payload.length === 0) return;\nconst color = '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0');\nconst resultPayload = [\n  { id: 0, p: 0, r: 0, c: 0, k: 'bg_color', t: 'str', v: color },\n  { id: 0, p: 0, r: 0, c: 0, k: 'status', t: 'str', v: 'processed' },\n  { id: 0, p: 0, r: 0, c: 0, k: 'submit_inflight', t: 'bool', v: false }\n];\nV1N.table.addLabel(0, 0, 0, 'bg_color', 'str', color);\nV1N.table.addLabel(0, 0, 0, 'status', 'str', 'processed');\nV1N.table.addLabel(0, 0, 0, 'submit_inflight', 'bool', false);\nconst topicLabel = V1N.readLabel(0, 0, 0, 'result_out_topic');\nconst topic = String(topicLabel && topicLabel.v ? topicLabel.v : '').trim();\nif (topic) {\n  ctx.publishMqtt(topic, { version: 'v1', type: 'pin_payload', op_id: 'color_response_' + Date.now(), source_model_id: 100, pin: 'result', payload: resultPayload, timestamp: Date.now() });\n}\nreturn resultPayload;",
        "modelName": "10_model100"
      }
    }
  ]
