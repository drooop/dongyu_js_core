      "k": "on_workspace_filltable_remote_submit_in",
      "t": "func.js",
      "v": {
        "code": "const payload = Array.isArray(label && label.v) ? label.v : [];\nconst inputRecord = payload.find((record) => record && record.k === 'input_value');\nconst text = String(inputRecord && inputRecord.v != null ? inputRecord.v : '').trim();\nlet hash = 0;\nfor (const ch of text) { hash = ((hash * 33) + ch.charCodeAt(0)) >>> 0; }\nconst color = '#' + (hash % 0xffffff).toString(16).padStart(6, '0');\nconst resultPayload = [\n  { id: 0, p: 0, r: 0, c: 0, k: 'generated_color_text', t: 'str', v: color },\n  { id: 0, p: 0, r: 0, c: 0, k: 'result_status', t: 'str', v: 'remote_processed' },\n  { id: 0, p: 0, r: 0, c: 0, k: 'submit_inflight', t: 'bool', v: false }\n];\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'generated_color_text' }, 'str', color);\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'result_status' }, 'str', 'remote_processed');\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', false);\nconst topic = String(ctx.getLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'result_out_topic' }) || '').trim();\nif (topic) ctx.publishMqtt(topic, { version: 'v1', type: 'pin_payload', op_id: 'ws_filltable_color_' + Date.now(), source_model_id: 1010, pin: 'result', payload: resultPayload, timestamp: Date.now() });\nreturn resultPayload;",
        "modelName": "workspace_filltable_example_truth"
      }
    }
