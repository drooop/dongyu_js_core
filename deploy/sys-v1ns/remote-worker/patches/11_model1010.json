      "p": 1,
      "r": 0,
      "c": 0,
      "k": "on_workspace_filltable_remote_event_in",
      "t": "func.js",
      "v": {
        "code": "const trigger = label.v;\nif (!trigger || typeof trigger !== 'object') return;\nconst raw = trigger.data && typeof trigger.data === 'object' ? trigger.data : {};\nconst text = String(raw.input_value || '').trim();\nlet hash = 0;\nfor (const ch of text) { hash = ((hash * 33) + ch.charCodeAt(0)) >>> 0; }\nconst color = '#' + (hash % 0xffffff).toString(16).padStart(6, '0');\nconst patch = {\n  version: 'mt.v0',\n  op_id: 'ws_filltable_color_' + Date.now(),\n  records: [\n    { op: 'add_label', model_id: 1010, p: 0, r: 0, c: 0, k: 'generated_color_text', t: 'str', v: color },\n    { op: 'add_label', model_id: 1010, p: 0, r: 0, c: 0, k: 'result_status', t: 'str', v: 'remote_processed' },\n    { op: 'add_label', model_id: 1010, p: 0, r: 0, c: 0, k: 'submit_inflight', t: 'bool', v: false }\n  ]\n};\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'generated_color_text' }, 'str', color);\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'result_status' }, 'str', 'remote_processed');\nctx.writeLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', false);\nconst topic = String(ctx.getLabel({ model_id: 1010, p: 0, r: 0, c: 0, k: 'patch_out_topic' }) || '').trim();\nif (topic) ctx.publishMqtt(topic, patch);\nreturn patch;",
        "modelName": "workspace_filltable_example_truth"
      }
