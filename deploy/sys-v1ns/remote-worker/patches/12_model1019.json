      "t": "func.js",
      "v": {
        "code": "const payload=Array.isArray(label&&label.v)?label.v:[];const textRecord=payload.find((record)=>record&&record.k==='message_text');const senderRecord=payload.find((record)=>record&&record.k==='sender_user_id');const roomRecord=payload.find((record)=>record&&record.k==='room_id');const text=String(textRecord&&textRecord.v!=null?textRecord.v:'').trim();const sender=String(senderRecord&&senderRecord.v!=null?senderRecord.v:'').trim()||'unknown';const roomId=String(roomRecord&&roomRecord.v!=null?roomRecord.v:'').trim()||'phase1-room';const reply='echo: '+text;const resultPayload=[{id:0,p:0,r:0,c:0,k:'last_remote_text',t:'str',v:reply},{id:0,p:0,r:0,c:0,k:'last_remote_sender',t:'str',v:'@mbr:localhost'},{id:0,p:0,r:0,c:0,k:'last_message_room_id',t:'str',v:roomId},{id:0,p:0,r:0,c:0,k:'last_sender_user_id',t:'str',v:sender},{id:0,p:0,r:0,c:0,k:'conversation_status',t:'str',v:'remote_processed'},{id:0,p:0,r:0,c:0,k:'submit_inflight',t:'bool',v:false}];ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'last_remote_text'},'str',reply);ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'last_remote_sender'},'str','@mbr:localhost');ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'last_message_room_id'},'str',roomId);ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'last_sender_user_id'},'str',sender);ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'conversation_status'},'str','remote_processed');ctx.writeLabel({model_id:1019,p:0,r:0,c:0,k:'submit_inflight'},'bool',false);const topic=String(ctx.getLabel({model_id:1019,p:0,r:0,c:0,k:'result_out_topic'})||'').trim();if(topic)ctx.publishMqtt(topic,{version:'v1',type:'pin_payload',op_id:'matrix_userline_phase1_'+Date.now(),source_model_id:1019,pin:'result',payload:resultPayload,timestamp:Date.now()});return resultPayload;",
