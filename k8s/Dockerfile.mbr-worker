FROM node:22-slim

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm install --omit=dev

# Copy worker-base runtime code only
COPY packages/worker-base/src/ ./packages/worker-base/src/
COPY packages/worker-base/system-models/ ./packages/worker-base/system-models/

# Copy generic worker bootstrap and engine
COPY scripts/run_worker_v0.mjs ./scripts/
COPY scripts/worker_engine_v0.mjs ./scripts/

CMD ["node", "scripts/run_worker_v0.mjs"]
