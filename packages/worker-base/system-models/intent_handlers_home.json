        "code": "const payload = label && label.v && typeof label.v === 'object' ? label.v : {}; const requests = Array.isArray(payload.requests) ? payload.requests : []; ctx.writeLabel({ model_id: -10, p: 0, r: 0, c: 0, k: 'home_pin_error' }, 'json', null); for (const req of requests) { if (!req || typeof req.out_pin !== 'string' || !req.out_pin || !req.body || typeof req.body !== 'object') { ctx.writeLabel({ model_id: -10, p: 0, r: 0, c: 0, k: 'home_pin_error' }, 'json', { code: 'invalid_request_shape', detail: 'requests[] item invalid' }); return; } ctx.writeLabel({ model_id: -10, p: 0, r: 0, c: 0, k: req.out_pin }, 'pin.table.out', req.body); }",
