{
  "version": "mt.v0",
  "op_id": "matrix_debug_surface_v0",
  "description": "Matrix debug surface model asset and observable defaults",
  "records": [
    {
      "op": "create_model",
      "model_id": -100,
      "name": "matrix_debug",
      "type": "Data"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "model_type",
      "t": "model.single",
      "v": "UI.MatrixDebugSurface"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "app_name",
      "t": "str",
      "v": "Matrix Debug"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "source_worker",
      "t": "str",
      "v": "system"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "data_type",
      "t": "str",
      "v": "CircularBuffer"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "size_max",
      "t": "int",
      "v": 2000
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_enabled",
      "t": "bool",
      "v": true
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_count",
      "t": "int",
      "v": 0
