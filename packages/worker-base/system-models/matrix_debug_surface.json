    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_status",
      "t": "str",
      "v": "monitoring"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_avg_latency",
      "t": "int",
      "v": 0
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_last_update",
      "t": "str",
      "v": "--:--:--"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_throughput",
      "t": "str",
      "v": "0/s"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_error_rate",
      "t": "str",
      "v": "0%"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_uptime",
      "t": "int",
      "v": 92
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "trace_log_text",
      "t": "str",
      "v": "(no events yet)"
    },
    {
      "op": "add_label",
      "model_id": -100,
      "p": 0,
      "r": 1,
      "c": 0,
      "k": "page_asset_v0",
      "t": "json",
      "v": {
        "id": "matrix_debug_root",
        "type": "Root",
        "children": [
          {
            "id": "matrix_debug_layout",
            "type": "Container",
            "props": {
              "layout": "column",
              "gap": 16,
              "style": {
                "padding": "16px",
                "maxWidth": "1180px",
                "margin": "0 auto"
              }
            },
            "children": [
              {
                "id": "matrix_debug_header_card",
                "type": "Card",
                "props": {
                  "title": "Matrix Debug Surface"
                },
                "children": [
                  {
                    "id": "matrix_debug_breadcrumb",
                    "type": "Breadcrumb",
                    "props": {
                      "items": [
                        {
                          "label": "Workspace"
                        },
                        {
                          "label": "Matrix Debug"
                        }
                      ]
                    }
                  },
                  {
                    "id": "matrix_debug_intro",
                    "type": "Text",
                    "props": {
                      "type": "info",
                      "text": "Observable server/Matrix/bridge trace state projected from Model -100."
                    }
                  }
                ]
              },
              {
                "id": "matrix_debug_status_row",
                "type": "Container",
                "props": {
                  "layout": "row",
                  "gap": 12,
                  "wrap": true
                },
                "children": [
                  {
                    "id": "matrix_debug_status_badge",
                    "type": "StatusBadge",
                    "props": {
                      "label": "STATUS",
                      "text": "monitoring"
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_status"
                      }
                    }
                  },
                  {
                    "id": "matrix_debug_enabled_hint",
                    "type": "Text",
                    "props": {
                      "type": "info",
                      "text": "Safe ops move to intent dispatch in Step 3. Step 2 only materializes the surface."
                    }
                  }
                ]
              },
              {
                "id": "matrix_debug_metrics_row",
                "type": "Container",
                "props": {
                  "layout": "row",
                  "gap": 12,
                  "wrap": true
                },
                "children": [
                  {
                    "id": "matrix_debug_stat_events",
                    "type": "StatCard",
                    "props": {
                      "label": "Events",
                      "unit": "total",
                      "variant": "info",
                      "style": {
                        "flex": 1
                      }
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_count"
                      }
                    }
                  },
                  {
                    "id": "matrix_debug_stat_latency",
                    "type": "StatCard",
                    "props": {
                      "label": "Avg Latency",
                      "unit": "ms",
                      "variant": "info",
                      "style": {
                        "flex": 1
                      }
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_avg_latency"
                      }
                    }
                  },
                  {
                    "id": "matrix_debug_stat_throughput",
                    "type": "StatCard",
                    "props": {
                      "label": "Throughput",
                      "variant": "info",
                      "style": {
                        "flex": 1
                      }
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_throughput"
                      }
                    }
                  },
                  {
                    "id": "matrix_debug_stat_errors",
                    "type": "StatCard",
                    "props": {
                      "label": "Error Rate",
                      "variant": "success",
                      "style": {
                        "flex": 1
                      }
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_error_rate"
                      }
                    }
                  }
                ]
              },
              {
                "id": "matrix_debug_actions_card",
                "type": "Card",
                "props": {
                  "title": "Planned Safe Ops"
                },
                "children": [
                  {
                    "id": "matrix_debug_actions_text",
                    "type": "Text",
                    "props": {
                      "type": "info",
                      "text": "Refresh / clear / summarize bind through intent dispatch in Step 3."
                    }
                  },
                  {
                    "id": "matrix_debug_actions_row",
                    "type": "Container",
                    "props": {
                      "layout": "row",
                      "gap": 8,
                      "wrap": true
                    },
                    "children": [
                      {
                        "id": "matrix_debug_refresh_button",
                        "type": "Button",
                        "props": {
                          "label": "Refresh (Step 3)",
                          "size": "small"
                        }
                      },
                      {
                        "id": "matrix_debug_clear_button",
                        "type": "Button",
                        "props": {
                          "label": "Clear Trace (Step 3)",
                          "size": "small"
                        }
                      },
                      {
                        "id": "matrix_debug_export_button",
                        "type": "Button",
                        "props": {
                          "label": "Export (Step 3)",
                          "size": "small"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "id": "matrix_debug_log_card",
                "type": "Card",
                "props": {
                  "title": "Recent Trace"
                },
                "children": [
                  {
                    "id": "matrix_debug_log_terminal",
                    "type": "Terminal",
                    "props": {
                      "title": "trace.log",
                      "showMacButtons": true,
                      "showToolbar": true,
                      "maxHeight": "420px"
                    },
                    "bind": {
                      "read": {
                        "model_id": -100,
                        "p": 0,
                        "r": 0,
                        "c": 0,
                        "k": "trace_log_text"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
