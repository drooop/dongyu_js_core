{
  "version": "mt.v0",
  "op_id": "prompt_catalog_ui_v0",
  "description": "Prompt FillTable page asset",
  "records": [
    {
      "op": "create_model",
      "model_id": -21,
      "name": "prompt_catalog",
      "type": "ui"
    },
    {
      "op": "add_label",
      "model_id": -21,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "ui_ast_v0",
      "t": "json",
      "v": {
        "id": "root_prompt_filltable",
        "type": "Root",
        "children": [
          {
            "id": "layout_prompt",
            "type": "Container",
            "props": { "layout": "column", "gap": 12 },
            "children": [
              {
                "id": "card_prompt_input",
                "type": "Card",
                "props": { "title": "Prompt FillTable" },
                "children": [
                  {
                    "id": "txt_prompt_desc",
                    "type": "Text",
                    "props": {
                      "type": "info",
                      "text": "输入自然语言，先 Preview（生成 owner-chain 预览，不落库），再 Apply（执行 owner 已确认的 accepted changes）。默认仅允许正数 model_id。"
                    }
                  },
                  {
                    "id": "txt_prompt_notice",
                    "type": "Text",
                    "props": { "type": "warning", "text": "" },
                    "bind": { "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_notice" } }
                  },
                  {
                    "id": "form_prompt",
                    "type": "Form",
                    "children": [
                      {
                        "id": "fi_prompt_text",
                        "type": "FormItem",
                        "props": { "label": "Prompt" },
                        "children": [
                          {
                            "id": "input_prompt_text",
                            "type": "Input",
                            "props": {
                              "type": "textarea",
                              "rows": 6,
                              "placeholder": "例如：把 Model 100 的 title 设为 Blue Team，并删除 obsolete_key"
                            },
                            "bind": {
                              "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_text" },
                              "write": { "action": "label_update", "target_ref": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_text" } }
                            }
                          }
                        ]
                      },
                      {
                        "id": "fi_prompt_actions",
                        "type": "FormItem",
                        "props": { "label": "Actions" },
                        "children": [
                          {
                            "id": "btn_prompt_preview",
                            "type": "Button",
                            "props": {
                              "type": "primary",
                              "label": "Preview",
                              "singleFlight": {
                                "key": "llm_filltable_preview",
                                "releaseRef": { "model_id": -1, "p": 0, "r": 0, "c": 1, "k": "ui_event_last_op_id" }
                              }
                            },
                            "bind": {
                              "write": {
                                "action": "llm_filltable_preview",
                                "target_ref": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_text" },
                                "meta_ref": { "local_only": true }
                              }
                            }
                          },
                          {
                            "id": "btn_prompt_use_latest_preview_id",
                            "type": "Button",
                            "props": { "label": "Use Latest Preview ID" },
                            "bind": {
                              "write": {
                                "action": "label_update",
                                "target_ref": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_preview_id" },
                                "value_ref": { "t": "str", "v": { "$label": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_preview_id" } } }
                              }
                            }
                          },
                          {
                            "id": "btn_prompt_apply",
                            "type": "Button",
                            "props": {
                              "type": "success",
                              "label": "Apply",
                              "singleFlight": {
                                "key": "llm_filltable_apply",
                                "releaseRef": { "model_id": -1, "p": 0, "r": 0, "c": 1, "k": "ui_event_last_op_id" }
                              }
                            },
                            "bind": {
                              "write": {
                                "action": "llm_filltable_apply",
                                "target_ref": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_preview_id" },
                                "meta_ref": { "local_only": true }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "id": "fi_prompt_preview_id",
                        "type": "FormItem",
                        "props": { "label": "Apply Preview ID" },
                        "children": [
                          {
                            "id": "input_prompt_apply_preview_id",
                            "type": "Input",
                            "props": { "placeholder": "preview id from latest preview" },
                            "bind": {
                              "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_preview_id" },
                              "write": { "action": "label_update", "target_ref": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_preview_id" } }
                            }
                          }
                        ]
                      },
                      {
                        "id": "txt_prompt_status",
                        "type": "Text",
                        "props": { "type": "info", "text": "" },
                        "bind": { "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_status" } }
                      }
                    ]
                  }
                ]
              },
              {
                "id": "card_prompt_preview_json",
                "type": "Card",
                "props": { "title": "Preview JSON" },
                "children": [
                  {
                    "id": "code_prompt_preview",
                    "type": "CodeBlock",
                    "props": { "style": { "maxHeight": "320px", "overflow": "auto", "whiteSpace": "pre-wrap", "wordBreak": "break-word" } },
                    "bind": { "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_preview_json" } }
                  }
                ]
              },
              {
                "id": "card_prompt_apply_json",
                "type": "Card",
                "props": { "title": "Apply Result JSON" },
                "children": [
                  {
                    "id": "code_prompt_apply_result",
                    "type": "CodeBlock",
                    "props": { "style": { "maxHeight": "320px", "overflow": "auto", "whiteSpace": "pre-wrap", "wordBreak": "break-word" } },
                    "bind": { "read": { "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_result_json" } }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_text", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_preview_json", "t": "json", "v": {} },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_preview_id", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_preview_digest", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_preview_id", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_apply_result_json", "t": "json", "v": {} },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_status", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_last_applied_preview_id", "t": "str", "v": "" },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_available", "t": "bool", "v": false },
    { "op": "add_label", "model_id": -2, "p": 0, "r": 0, "c": 0, "k": "llm_prompt_notice", "t": "str", "v": "当前暂不可用：仅远端模式支持 LLM。" }
  ]
}
