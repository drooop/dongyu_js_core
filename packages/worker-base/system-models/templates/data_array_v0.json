        "modelName": "data_array_v0",
        "code": "const SELF_MODEL_ID=ctx.self.model_id;const root={model_id:SELF_MODEL_ID,p:0,r:0,c:0};const payload=Array.isArray(label&&label.v)?label.v:[];const valueRecord=payload.find((record)=>record&&record.k==='value');if(!valueRecord||typeof valueRecord.t!=='string') throw new Error('invalid_add_payload');const size=Number(ctx.getLabel({...root,k:'size_now'})||0);const next=Number(ctx.getLabel({...root,k:'next_index'})||1);ctx.writeLabel({model_id:SELF_MODEL_ID,p:0,r:next,c:0,k:'value'},valueRecord.t||'json',valueRecord.v);ctx.writeLabel({...root,k:'size_now'},'int',size+1);ctx.writeLabel({...root,k:'next_index'},'int',next+1);"
