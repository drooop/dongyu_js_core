        "code": "const idx=Number(label&&label.v&&label.v.index);if(!Number.isInteger(idx)||idx<1) throw new Error('invalid_get_payload');const size=Number(ctx.getLabel({model_id:2001,p:0,r:0,c:0,k:'size_now'})||0);if(idx>size) return {index:idx,found:false,value:null};const value=ctx.getLabel({model_id:2001,p:0,r:idx,c:0,k:'value'});return {index:idx,found:value!==undefined,value:value===undefined?null:value};"
