        "modelName": "data_array_v0",
        "code": "const root={model_id:2001,p:0,r:0,c:0};const idx=Number(label&&label.v&&label.v.index);if(!Number.isInteger(idx)||idx<1) throw new Error('invalid_delete_payload');const size=Number(ctx.getLabel({...root,k:'size_now'})||0);if(idx>size) throw new Error('delete_index_out_of_range');for(let i=idx+1;i<=size;i++){const moved=ctx.getLabel({model_id:2001,p:0,r:i,c:0,k:'value'});ctx.writeLabel({model_id:2001,p:0,r:i-1,c:0,k:'value'},'json',moved);}ctx.rmLabel({model_id:2001,p:0,r:size,c:0,k:'value'});ctx.writeLabel({...root,k:'size_now'},'int',size-1);ctx.writeLabel({...root,k:'next_index'},'int',size);"
