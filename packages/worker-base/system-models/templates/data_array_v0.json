      "v": {
        "modelName": "data_array_v0",
        "code": "const root={model_id:2001,p:0,r:0,c:0};if(!label||!label.v||typeof label.v!=='object'||!Object.prototype.hasOwnProperty.call(label.v,'value')) throw new Error('invalid_add_payload');const size=Number(ctx.getLabel({...root,k:'size_now'})||0);const next=Number(ctx.getLabel({...root,k:'next_index'})||1);ctx.writeLabel({model_id:2001,p:0,r:next,c:0,k:'value'},'json',label.v.value);ctx.writeLabel({...root,k:'size_now'},'int',size+1);ctx.writeLabel({...root,k:'next_index'},'int',next+1);"
