      "t": "func.js",
      "v": {
        "modelName": "data_queue_v0",
        "code": "const payload=Array.isArray(label&&label.v)?label.v:[];const valueRecord=payload.find((record)=>record&&record.k==='value');if(!valueRecord||typeof valueRecord.t!=='string') throw new Error('invalid_enqueue_payload');const sizeLbl=V1N.readLabel(0,0,0,'size_now');const nextLbl=V1N.readLabel(0,0,0,'next_index');const size=Number(sizeLbl?sizeLbl.v:0);const next=Number(nextLbl?nextLbl.v:1);V1N.table.addLabel(0,next,0,'value',valueRecord.t||'json',valueRecord.v);V1N.addLabel('size_now','int',size+1);V1N.addLabel('next_index','int',next+1);"
      }
