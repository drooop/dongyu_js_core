        "code": "const payload=Array.isArray(label&&label.v)?label.v:[];if(payload.some((record)=>record&&record.k!=='model_type')) throw new Error('pop_payload_must_be_zero_arg');const sizeLbl=V1N.readLabel(0,0,0,'size_now');const size=Number(sizeLbl?sizeLbl.v:0);if(size<1)return[{id:0,p:0,r:0,c:0,k:'model_type',t:'model.single',v:'Data.Single'},{id:0,p:0,r:0,c:0,k:'found',t:'bool',v:false},{id:0,p:0,r:0,c:0,k:'value',t:'json',v:null}];const valLbl=V1N.readLabel(0,size,0,'value');const value=valLbl?valLbl.v:null;V1N.table.removeLabel(0,size,0,'value');V1N.addLabel('size_now','int',size-1);V1N.addLabel('next_index','int',size);return[{id:0,p:0,r:0,c:0,k:'model_type',t:'model.single',v:'Data.Single'},{id:0,p:0,r:0,c:0,k:'found',t:'bool',v:true},{id:0,p:0,r:0,c:0,k:'value',t:'json',v:value}];"
