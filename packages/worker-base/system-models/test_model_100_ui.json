    {
      "op": "add_label",
      "model_id": -10,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "prepare_model100_submit",
      "t": "func.js",
      "v": {
        "code": "const event = ctx.getLabel({ model_id: 100, p: 0, r: 0, c: 2, k: 'bus_event' });\nif (!event || typeof event !== 'object') return;\nconsole.log('[prepare_model100_submit] Event:', JSON.stringify(event));\nconst inflight = ctx.getLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight' });\nconst startedAt = Number(ctx.getLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight_started_at' }) || 0);\nconst TIMEOUT_MS = 30000;\nconst now = Date.now();\nif (inflight === true) {\n  const stale = !Number.isFinite(startedAt) || (now - startedAt > TIMEOUT_MS);\n  if (stale) {\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', false);\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight_started_at' }, 'int', 0);\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'status' }, 'str', 'ready');\n  } else {\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 1, k: 'bus_event_error' }, 'json', { code: 'busy', detail: 'model100_submit_inflight' });\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 1, k: 'bus_event_last_op_id' }, 'str', '');\n    ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 2, k: 'bus_event' }, 'event', null);\n    return;\n  }\n}\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', true);\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight_started_at' }, 'int', now);\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'status' }, 'str', 'loading');\nconst inputValue = String(event.input_value != null ? event.input_value : '');\nconst payload = [\n  { id: 0, p: 0, r: 0, c: 0, k: 'model_type', t: 'model.single', v: 'Data.RemoteSubmit' },\n  { id: 0, p: 0, r: 0, c: 0, k: 'input_value', t: 'str', v: inputValue },\n  { id: 0, p: 0, r: 0, c: 0, k: 'route_mode', t: 'str', v: 'remote' }\n];\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit' }, 'pin.out', payload);\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 2, k: 'bus_event' }, 'event', null);\nctx.rmLabel({ model_id: -10, p: 0, r: 0, c: 0, k: 'run_prepare_model100_submit' });",
        "modelName": "test_model_100_ui"
      }
    },
    {
      "op": "add_label",
      "model_id": -10,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "forward_model100_submit_from_model0",
      "t": "func.js",
      "v": {
        "code": "const payload = ctx.getLabel({ model_id: 0, p: 0, r: 0, c: 0, k: 'model100_submit_out' });\nif (!Array.isArray(payload) || payload.length === 0) return;\nconst packet = { version: 'v1', type: 'pin_payload', op_id: 'm100_' + Date.now(), source_model_id: 100, pin: 'submit', payload, timestamp: Date.now() };\nconst p = ctx.sendMatrix(packet);\nif (p && typeof p.then === 'function') {\n  p.then(function() { console.log('[forward_model100_submit_from_model0] Matrix send OK, op_id:', packet.op_id); })\n   .catch(function(err) {\n     console.warn('[forward_model100_submit_from_model0] Matrix send failed (non-fatal):', err.message);\n     ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', false);\n     ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight_started_at' }, 'int', 0);\n     ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'status' }, 'str', 'send_failed');\n   });\n} else if (!p) {\n  console.warn('[forward_model100_submit_from_model0] Matrix not available, cannot forward event');\n  ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight' }, 'bool', false);\n  ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit_inflight_started_at' }, 'int', 0);\n  ctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'status' }, 'str', 'matrix_unavailable');\n}\nctx.writeLabel({ model_id: 0, p: 0, r: 0, c: 0, k: 'model100_submit_out' }, 'pin.in', null);\nctx.writeLabel({ model_id: 100, p: 0, r: 0, c: 0, k: 'submit' }, 'pin.out', null);\nctx.rmLabel({ model_id: -10, p: 0, r: 0, c: 0, k: 'run_forward_model100_submit_from_model0' });",
        "modelName": "test_model_100_ui"
