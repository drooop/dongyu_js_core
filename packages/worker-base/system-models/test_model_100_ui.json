    {
      "op": "add_label",
      "model_id": -10,
      "p": 0,
      "r": 0,
      "c": 0,
      "k": "prepare_model100_submit_from_pin",
      "t": "func.js",
      "v": {
        "code": "const eventPayload = Array.isArray(label && label.v) ? label.v : [];\nif (eventPayload.length === 0) return;\nconst readPayload = (key, fallback = null) => {\n  const record = eventPayload.find((rec) => rec && rec.id === 0 && rec.p === 0 && rec.r === 0 && rec.c === 0 && rec.k === key);\n  return record && Object.prototype.hasOwnProperty.call(record, 'v') ? record.v : fallback;\n};\nconsole.log('[prepare_model100_submit_from_pin] Event:', JSON.stringify(eventPayload));\nconst readValue = (tp, tr, tc, key, fallback = null) => {\n  const next = V1N.readLabel(tp, tr, tc, key);\n  return next && Object.prototype.hasOwnProperty.call(next, 'v') ? next.v : fallback;\n};\nconst writeRoot = (key, type, value) => V1N.table.addLabel(0, 0, 0, key, type, value);\nconst writeMailbox = (key, type, value) => V1N.table.addLabel(0, 0, 1, key, type, value);\nconst inflight = readValue(0, 0, 0, 'submit_inflight', false) === true;\nconst startedAt = Number(readValue(0, 0, 0, 'submit_inflight_started_at', 0) || 0);\nconst TIMEOUT_MS = 30000;\nconst now = Date.now();\nif (inflight === true) {\n  const stale = !Number.isFinite(startedAt) || (now - startedAt > TIMEOUT_MS);\n  if (stale) {\n    writeRoot('submit_inflight', 'bool', false);\n    writeRoot('submit_inflight_started_at', 'int', 0);\n    writeRoot('status', 'str', 'ready');\n  } else {\n    writeMailbox('bus_event_error', 'json', { code: 'busy', detail: 'model100_submit_inflight' });\n    writeMailbox('bus_event_last_op_id', 'str', '');\n    return;\n  }\n}\nwriteRoot('submit_inflight', 'bool', true);\nwriteRoot('submit_inflight_started_at', 'int', now);\nwriteRoot('status', 'str', 'loading');\nwriteMailbox('bus_event_error', 'json', null);\nconst inputValue = String(readPayload('input_value', ''));\nconst payload = [\n  { id: 0, p: 0, r: 0, c: 0, k: 'model_type', t: 'model.single', v: 'Data.RemoteSubmit' },\n  { id: 0, p: 0, r: 0, c: 0, k: 'input_value', t: 'str', v: inputValue },\n  { id: 0, p: 0, r: 0, c: 0, k: 'route_mode', t: 'str', v: 'remote' }\n];\nwriteRoot('submit', 'pin.out', payload);",
        "modelName": "test_model_100_ui"
