      "steps": [
        { "pin": "add_data_in", "payload": [
          { "id": 0, "p": 0, "r": 0, "c": 0, "k": "model_type", "t": "model.single", "v": "Data.Single" },
          { "id": 0, "p": 0, "r": 0, "c": 0, "k": "value", "t": "json", "v": "A" }
