{
  "cases": [
    {
      "name": "add_two_items_and_read_size_and_all",
      "steps": [
        { "pin": "add_data_in", "payload": { "value": "A" } },
        { "pin": "add_data_in", "payload": { "value": "B" } },
        { "pin": "get_size_in", "payload": null },
        { "pin": "get_all_data_in", "payload": null }
      ],
      "expected": {
        "size_now": 2,
        "next_index": 3,
        "rows": {
          "1": "A",
          "2": "B"
        },
        "get_size_out": { "size": 2 },
        "get_all_data_out": {
          "items": ["A", "B"],
          "size": 2
        }
      }
    },
    {
      "name": "get_by_index_and_delete_with_compact",
      "steps": [
        { "pin": "add_data_in", "payload": { "value": "A" } },
        { "pin": "add_data_in", "payload": { "value": "B" } },
        { "pin": "add_data_in", "payload": { "value": "C" } },
        { "pin": "get_data_in", "payload": { "index": 2 } },
        { "pin": "delete_data_in", "payload": { "index": 1 } }
      ],
      "expected": {
        "size_now": 2,
        "next_index": 3,
        "rows": {
          "1": "B",
          "2": "C"
        },
        "get_data_out": {
          "index": 2,
          "found": true,
          "value": "B"
        }
      }
    }
  ]
}
