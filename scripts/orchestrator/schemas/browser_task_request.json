{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "browser_task_request.v1",
  "title": "Browser Task Request v1",
  "description": "Structured request envelope for a browser-capable executor. Request/result exchange files live under .orchestrator, while operator-facing artifacts live under output/playwright and are not authoritative until orchestrator ingest.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "browser_task_request.v1",
      "description": "Versioned browser_task request contract"
    },
    "task_kind": {
      "const": "browser_task",
      "description": "Explicitly distinguishes browser_task from generic CLI execution"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "iteration_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executor_class": {
          "const": "browser_capable",
          "description": "Executor boundary is browser-capable, not an implicit codex/claude child process"
        },
        "bridge_channel": {
          "const": "browser_task_bridge",
          "description": "Structured bridge channel used for browser request/result exchange"
        },
        "executor_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["mock", "mcp"],
          "description": "mock is allowed for 0218-0220 contract/regression; mcp is required for real bridge proof"
        }
      },
      "required": ["executor_class", "bridge_channel", "executor_id", "mode"]
    },
    "exchange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_file": {
          "type": "string",
          "pattern": "^\\.orchestrator/runs/[^/]+/browser_tasks/[^/]+/request\\.json$"
        },
        "result_file": {
          "type": "string",
          "pattern": "^\\.orchestrator/runs/[^/]+/browser_tasks/[^/]+/result\\.json$"
        },
        "task_dir": {
          "type": "string",
          "pattern": "^\\.orchestrator/runs/[^/]+/browser_tasks/[^/]+$"
        }
      },
      "required": ["request_file", "result_file", "task_dir"]
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "start_url": {
          "type": "string",
          "minLength": 1
        },
        "instructions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "success_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["summary", "instructions", "success_assertions"]
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "artifact_kind": {
            "type": "string",
            "enum": ["screenshot", "json", "trace", "console"]
          },
          "relative_path": {
            "type": "string",
            "pattern": "^output/playwright/[^/]+/[^/]+/.+"
          },
          "required": {
            "type": "boolean"
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["artifact_kind", "relative_path", "required", "media_type"]
      }
    }
  },
  "required": [
    "schema_version",
    "task_kind",
    "batch_id",
    "iteration_id",
    "task_id",
    "attempt",
    "created_at",
    "executor",
    "exchange",
    "objective",
    "timeout_ms",
    "required_artifacts"
  ]
}
