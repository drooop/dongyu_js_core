{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "browser_task_result.v1",
  "title": "Browser Task Result v1",
  "description": "Structured result envelope emitted by a browser-capable executor. The result file is a batch-local exchange file; artifacts remain local evidence until orchestrator ingests them into state/events/runlog.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "browser_task_result.v1",
      "description": "Versioned browser_task result contract"
    },
    "task_kind": {
      "const": "browser_task",
      "description": "Explicitly distinguishes browser_task result from generic CLI execution"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "iteration_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "failure_kind": {
      "type": "string",
      "enum": [
        "none",
        "request_invalid",
        "executor_unavailable",
        "mcp_unavailable",
        "timeout",
        "cancelled",
        "result_invalid",
        "artifact_missing",
        "artifact_mismatch",
        "stale_result",
        "duplicate_result",
        "ingest_failed",
        "browser_bridge_not_proven"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executor_class": {
          "const": "browser_capable"
        },
        "bridge_channel": {
          "const": "browser_task_bridge"
        },
        "executor_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["mock", "mcp"]
        }
      },
      "required": ["executor_class", "bridge_channel", "executor_id", "mode"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "artifact_kind": {
            "type": "string",
            "enum": ["screenshot", "json", "trace", "console"]
          },
          "relative_path": {
            "type": "string",
            "pattern": "^output/playwright/[^/]+/[^/]+/.+"
          },
          "required": {
            "type": "boolean"
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "producer": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "actor": {
                "const": "browser_executor"
              },
              "executor_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["actor", "executor_id"]
          }
        },
        "required": [
          "artifact_kind",
          "relative_path",
          "required",
          "media_type",
          "bytes",
          "sha256",
          "producer"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "task_kind",
    "batch_id",
    "iteration_id",
    "task_id",
    "attempt",
    "status",
    "failure_kind",
    "summary",
    "executor",
    "started_at",
    "completed_at",
    "artifacts"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        }
      },
      "then": {
        "properties": {
          "failure_kind": {
            "const": "none"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "fail"
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "failure_kind": {
              "const": "none"
            }
          }
        }
      }
    }
  ]
}
