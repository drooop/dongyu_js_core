  {
    "id": 0,
    "p": 0,
    "r": 0,
    "c": 0,
    "k": "handle_todo_event",
    "t": "func.js",
    "v": {
      "code": "const records = Array.isArray(label && label.v) ? label.v : [];\nconst readPayload = (key, fallback = '') => {\n  const rec = records.find((item) => item && item.id === 0 && item.p === 0 && item.r === 0 && item.c === 0 && item.k === key);\n  return rec && Object.prototype.hasOwnProperty.call(rec, 'v') ? rec.v : fallback;\n};\nconst read = (key, fallback = '') => {\n  const lbl = V1N.readLabel(0, 0, 0, key);\n  return lbl && Object.prototype.hasOwnProperty.call(lbl, 'v') ? lbl.v : fallback;\n};\nconst write = (key, type, value) => V1N.table.addLabel(0, 0, 0, key, type, value);\nconst tasks = () => Array.isArray(read('tasks_json', [])) ? read('tasks_json', []) : [];\nconst clean = (value) => String(value == null ? '' : value).trim();\nconst validStatus = (value) => ['todo', 'doing', 'done', 'archived'].includes(value) ? value : 'todo';\nconst stamp = () => new Date().toISOString();\nconst fail = (code, detail) => { write('todo_status', 'str', 'ERR ' + code + ': ' + detail); write('last_error_json', 'json', { code, detail, ts: Date.now() }); };\nif (readPayload('__mt_payload_kind', '') !== 'ui_event.v1') { fail('invalid_payload_kind', 'ui_event.v1_required'); return; }\nconst action = clean(readPayload('todo_action', ''));\nlet list = tasks();\ntry {\n  if (action === 'open_create') {\n    write('draft_title', 'str', '');\n    write('draft_body', 'str', '');\n    write('draft_status', 'str', 'todo');\n    write('create_dialog_open', 'bool', true);\n    write('todo_status', 'str', 'ready to create');\n  } else if (action === 'close_create') {\n    write('create_dialog_open', 'bool', false);\n  } else if (action === 'create_task') {\n    const title = clean(readPayload('title', read('draft_title', '')));\n    if (!title) { fail('missing_title', 'draft_title_required'); return; }\n    const body = String(readPayload('body', read('draft_body', '')) || '').trim();\n    const status = validStatus(clean(readPayload('status', read('draft_status', 'todo'))));\n    const id = 'task_' + Date.now() + '_' + Math.random().toString(16).slice(2, 7);\n    const ts = stamp();\n    list = [{ id, title, body, status, created_at: ts, updated_at: ts }, ...list];\n    write('tasks_json', 'json', list);\n    write('draft_title', 'str', '');\n    write('draft_body', 'str', '');\n    write('draft_status', 'str', 'todo');\n    write('create_dialog_open', 'bool', false);\n    write('todo_status', 'str', 'created: ' + title);\n  } else if (action === 'open_edit') {\n    const taskId = clean(readPayload('task_id', ''));\n    const task = list.find((item) => item && item.id === taskId);\n    if (!task) { fail('task_not_found', taskId); return; }\n    write('selected_task_id', 'str', task.id);\n    write('edit_title', 'str', task.title || '');\n    write('edit_body', 'str', task.body || '');\n    write('edit_status', 'str', validStatus(task.status));\n    write('edit_dialog_open', 'bool', true);\n    write('todo_status', 'str', 'editing: ' + task.title);\n  } else if (action === 'close_edit') {\n    write('edit_dialog_open', 'bool', false);\n  } else if (action === 'save_edit') {\n    const taskId = clean(readPayload('task_id', read('selected_task_id', '')));\n    const title = clean(readPayload('title', read('edit_title', '')));\n    if (!taskId || !title) { fail('missing_edit_target', 'selected_task_id_and_title_required'); return; }\n    const body = String(readPayload('body', read('edit_body', '')) || '').trim();\n    const status = validStatus(clean(readPayload('status', read('edit_status', 'todo'))));\n    let changed = false;\n    const ts = stamp();\n    list = list.map((task) => {\n      if (!task || task.id !== taskId) return task;\n      changed = true;\n      return { ...task, title, body, status, updated_at: ts };\n    });\n    if (!changed) { fail('task_not_found', taskId); return; }\n    write('tasks_json', 'json', list);\n    write('edit_dialog_open', 'bool', false);\n    write('todo_status', 'str', 'saved: ' + title);\n  } else if (action === 'move_status') {\n    const taskId = clean(readPayload('task_id', ''));\n    const status = validStatus(clean(readPayload('status', 'todo')));\n    let changed = false;\n    const ts = stamp();\n    list = list.map((task) => {\n      if (!task || task.id !== taskId) return task;\n      changed = true;\n      return { ...task, status, updated_at: ts };\n    });\n    if (!changed) { fail('task_not_found', taskId); return; }\n    write('tasks_json', 'json', list);\n    write('todo_status', 'str', 'moved to ' + status);\n  } else if (action === 'filter_focus') {\n    write('filter_text', 'str', clean(readPayload('filter_text', read('filter_text', ''))));\n    write('todo_status', 'str', 'filter updated');\n  } else {\n    fail('unknown_action', action || 'missing'); return;\n  }\n  write('last_action', 'str', action);\n  write('last_error_json', 'json', null);\n} catch (err) { fail('exception', err && err.message ? err.message : String(err)); }",
      "modelName": "todo_board"
    }
