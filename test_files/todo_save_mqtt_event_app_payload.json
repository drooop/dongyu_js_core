    "k": "handle_todo_save",
    "t": "func.js",
    "v": {
      "code": "const records = Array.isArray(label && label.v) ? label.v : [];\nconst readPayload = (key, fallback = '') => {\n  const rec = records.find((item) => item && item.id === 0 && item.p === 0 && item.r === 0 && item.c === 0 && item.k === key);\n  return rec && Object.prototype.hasOwnProperty.call(rec, 'v') ? rec.v : fallback;\n};\nconst mt = (k, t, v) => ({ id: 0, p: 0, r: 0, c: 0, k, t, v });\nconst clean = (value) => String(value == null ? '' : value).trim();\nconst validStatus = (value) => ['todo', 'doing', 'done', 'archived'].includes(value) ? value : 'todo';\nconst fail = (code, detail) => {\n  V1N.addLabel('todo_save_status', 'str', 'ERR ' + code + ': ' + detail);\n  V1N.addLabel('last_error_json', 'json', { code, detail, ts: Date.now() });\n  V1N.addLabel('submit_inflight', 'bool', false);\n};\nif (readPayload('__mt_payload_kind', '') !== 'ui_event.v1') { fail('invalid_payload_kind', 'ui_event.v1_required'); return; }\nconst action = clean(readPayload('todo_action', ''));\nif (action !== 'save_task') { fail('unknown_action', action || 'missing'); return; }\nconst title = clean(readPayload('title', ''));\nif (!title) { fail('missing_title', 'title_required'); return; }\nconst body = clean(readPayload('body', ''));\nconst status = validStatus(clean(readPayload('status', 'todo')));\nconst taskPayload = [\n  mt('__mt_payload_kind', 'str', 'todo_save.request.v1'),\n  mt('todo_action', 'str', 'save_task'),\n  mt('title', 'str', title),\n  mt('body', 'str', body),\n  mt('status', 'str', status),\n  mt('source', 'str', 'todo_save_mqtt_example')\n];\nV1N.addLabel('draft_title', 'str', title);\nV1N.addLabel('draft_body', 'str', body);\nV1N.addLabel('draft_status', 'str', status);\nV1N.addLabel('last_submit_payload', 'json', taskPayload);\nV1N.addLabel('last_error_json', 'json', null);\nV1N.addLabel('todo_save_status', 'str', 'sending: ' + title);\nV1N.addLabel('submit_inflight', 'bool', true);\nV1N.addLabel('submit1', 'pin.out', taskPayload);\nreturn;"
    }
  },
